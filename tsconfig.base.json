{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@sprite/shared": ["packages/shared/src/index.ts"],
      "@sprite/core": ["packages/core/src/index.ts"],
      "@sprite/config": ["packages/config/src/index.ts"],
      "@sprite/providers": ["packages/providers/src/index.ts"],
      "@sprite/sandbox": ["packages/sandbox/src/index.ts"],
      "@sprite/tools": ["packages/tools/src/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
